@page "/calculadora"
@rendermode InteractiveServer
@using CalculadoraDebitos.DTO
@using CalculadoraDebitos.Services

@inject CalculadoraService CalculadoraService

<!-- ENTRADA -->
<div style="display: flex; justify-content: center; margin-bottom: 32px;">
    <div style="max-width: 900px; width: 100%;">

        <FluentGrid Columns="12" Gap="16px">

            <div style="grid-column: span 4;">
                <FluentTextField Label="Valor Principal"
                                 @bind-Value="valorPrincipalTexto" />
            </div>

            <div style="grid-column: span 3;">
                <FluentDatePicker Label="Vencimento"
                                  Value="vencimento"
                                  ValueChanged="@(d => vencimento = d ?? DateTime.Today)"
                                  AnchoredRegionFixedPlacement="true" />
            </div>

            <div style="grid-column: span 3;">
                <FluentDatePicker Label="Pagamento"
                                  Value="pagamento"
                                  ValueChanged="@(d => pagamento = d ?? DateTime.Today)"
                                  AnchoredRegionFixedPlacement="true" />
            </div>

            <div style="grid-column: span 2; display: flex; align-items: end;">
                <FluentButton Appearance="Appearance.Accent"
                              OnClick="Calcular"
                              Style="width: 100%;">
                    Calcular
                </FluentButton>
            </div>

        </FluentGrid>

    </div>
</div>

@if (resultado != null)
{
    <div style="display: flex; justify-content: center;">
        <div style="max-width: 900px; width: 100%;">

            <!-- RESUMO -->
            <FluentGrid Columns="4" Gap="16px" Class="mb-5">

                <FluentCard Class="p-3">
                    <small>Principal</small>
                    <h5>@resultado.Principal.ToString("C")</h5>
                </FluentCard>

                <FluentCard Class="p-3">
                    <small>UFFI</small>
                    <h5>@resultado.CorrecaoUffi.ToString("C")</h5>
                </FluentCard>

                <FluentCard Class="p-3">
                    <small>SELIC</small>
                    <h5>@resultado.CorrecaoSelic.ToString("C")</h5>
                </FluentCard>

                <FluentCard Class="p-3" Style="border-left: 4px solid var(--accent-fill-rest);">
                    <small>Total</small>
                    <h4 style="font-weight: bold;">
                        @resultado.Total.ToString("C")
                    </h4>
                </FluentCard>

            </FluentGrid>

            <!-- MEMÓRIAS -->
            <FluentGrid Columns="2" Gap="16px">

                @if (resultado?.MemoriaUffi?.Any(x => x.TaxaAnoVencimento != x.TaxaAnoCorrecao) == true)
                {
                    <FluentCard Class="p-3">

                        <h5>Memória UFFI</h5>

                        <FluentDataGrid TItem="ItemUffi"
                                        Items="@((resultado.MemoriaUffi ?? new List<ItemUffi>()).AsQueryable())">

                            <PropertyColumn Property="@(c => c.AnoVenciento)" Title="Ano Venc." />
                            <PropertyColumn Property="@(c => c.TaxaAnoVencimento)" Title="UFFI Venc." />
                            <PropertyColumn Property="@(c => c.AnoCorrecao)" Title="Ano Corr." />
                            <PropertyColumn Property="@(c => c.TaxaAnoCorrecao)" Title="UFFI Corr." />
                            <PropertyColumn Property="@(c => c.Taxa)" Title="Taxa" />
                            <PropertyColumn Property="@(c => c.Base)" Title="Base" />
                            <!-- 

                            <PropertyColumn Property="@(c => c.Valor)" Title="Valor" />
                            -->
                            <PropertyColumn Property="@(c => c.Valor)" Title="Valor" Format="N2" />

                        </FluentDataGrid>

                    </FluentCard>
                }

                <FluentCard Class="p-3">

                    <h5>Memória SELIC</h5>

                    <FluentDataGrid TItem="ItemSelic"
                                    Items="@((resultado.MemoriaSelic ?? new List<ItemSelic>()).AsQueryable())">

                        <PropertyColumn Property="@(c => c.Ano)" Title="Ano" />
                        <PropertyColumn Property="@(c => c.Mes)" Title="Mês" />
                        <PropertyColumn Property="@(c => c.Taxa)" Title="Taxa" />
                        <PropertyColumn Property="@(c => c.Base)" Title="Base" />
                        <!-- 
                        <PropertyColumn Property="@(c => c.Valor)" Title="Valor" />

                        -->
                        <PropertyColumn Property="@(c => c.Valor)" Title="Valor" Format="N2" />

                    </FluentDataGrid>

                </FluentCard>

            </FluentGrid>

        </div>
    </div>
}

@code {

    string valorPrincipalTexto = "0";

    decimal valorPrincipal;

    DateTime vencimento = new DateTime(DateTime.Today.Year, 1, 1);
    DateTime pagamento = DateTime.Today;

    ResultadoCalculo? resultado;

    async Task Calcular()
    {
        decimal.TryParse(valorPrincipalTexto, out valorPrincipal);

        resultado = await CalculadoraService.Calcular(
            valorPrincipal,
            vencimento,
            pagamento);
    }
}